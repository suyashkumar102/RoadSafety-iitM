{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roadsos.local/contracts/contact.schema.json",
  "title": "RoadSoS Emergency Service Contact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "type",
    "lat",
    "lon",
    "phone",
    "address",
    "locality",
    "region",
    "country",
    "source_url",
    "source_name",
    "verified_at",
    "availability",
    "confidence_score",
    "confidence_reasons",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$"
    },
    "name": {
      "type": "string",
      "minLength": 2
    },
    "type": {
      "type": "string",
      "enum": [
        "hospital",
        "trauma_center",
        "ambulance",
        "police",
        "tow",
        "repair",
        "fallback_emergency"
      ]
    },
    "lat": {
      "type": [
        "number",
        "null"
      ],
      "minimum": -90,
      "maximum": 90
    },
    "lon": {
      "type": [
        "number",
        "null"
      ],
      "minimum": -180,
      "maximum": 180
    },
    "phone": {
      "type": "string",
      "minLength": 2
    },
    "address": {
      "type": [
        "string",
        "null"
      ]
    },
    "locality": {
      "type": "string",
      "minLength": 2
    },
    "region": {
      "type": "string",
      "minLength": 2
    },
    "country": {
      "type": "string",
      "minLength": 2
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "source_name": {
      "type": "string",
      "minLength": 2
    },
    "verified_at": {
      "type": "string",
      "format": "date"
    },
    "availability": {
      "type": "string",
      "minLength": 2
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence_reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
